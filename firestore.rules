rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check for Admin status (Invisible to Client-Side Inspect)
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'sutharamit344@gmail.com' || 
         request.auth.token.email == 'webiestindiasolution@gmail.com' ||
         request.auth.token.email == 'admin@shopsetu.com');
    }

    match /shops/{shopId} {
      allow read: if resource.data.status == 'approved' || request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (isAdmin() || request.auth.uid == resource.data.ownerId);
      allow delete: if isAdmin();

      match /ratings/{ratingId} {
        allow read: if true;
        allow create: if request.resource.data.rating >= 1 && request.resource.data.rating <= 5;
        allow delete: if isAdmin();
      }
    }

    match /categories/{catId} {
      allow read: if true;
      allow create: if request.auth != null && (isAdmin() || request.resource.data.status == 'pending');
      allow update, delete: if isAdmin();
    }

    match /clusters/{clusterId} {
      allow read: if true;
      allow create: if request.auth != null && (isAdmin() || request.resource.data.status == 'pending');
      allow update, delete: if isAdmin();
    }

    match /meta/adminCheck {
      allow read: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }
  }
}
